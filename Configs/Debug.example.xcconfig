// Debug build - local development.
// Copy this file to Debug.xcconfig. The real file is gitignored.
//
// Note: `//` starts a comment, so URLs use `$()` to break the `//`
// e.g. `http:/$()/localhost:3000` yields `http://localhost:3000` at build time.

API_BASE_URL = http:/$()/localhost:3000/api/companion/
WEB_BASE_URL = http:/$()/localhost:3000
SUPABASE_URL = http:/$()/127.0.0.1:54321
SUPABASE_ANON_KEY = sb_publishable_REPLACE_ME
